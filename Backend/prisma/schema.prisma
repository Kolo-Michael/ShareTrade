// ShareTrade P2P — Prisma Schema
// Database: PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════

enum Role {
  INVESTOR
  COMPANY
  ADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  // Investor documents
  PASSPORT
  CNI_FRONT
  CNI_BACK
  PROOF_OF_ADDRESS
  SELFIE_WITH_ID
  // Company documents
  RCCM_CERT
  STATUTS
  NIU_ATTESTATION
  ATTESTATION_LOCALISATION
  PLAN_LOCALISATION
  PV_ASSEMBLEE
  REP_ID
  PATENTE
  OHADA_DEED
}

enum DocStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum TradeStatus {
  PENDING
  ESCROW_LOCKED
  COMPANY_APPROVED
  COMPANY_REJECTED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum TradeType {
  BUY
  SELL
}

enum EscrowStatus {
  LOCKED
  RELEASED
  REFUNDED
  DISPUTED
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_REFUND
  TRADE_CREDIT
  TRADE_DEBIT
  FEE
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  ORANGE_MONEY
  EXPRESS_UNION
  BANK_BICEC
  BANK_AFRILAND
  WESTERN_UNION
  INTERNAL
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  RESOLVED_SPLIT
  CLOSED
}

enum NotifType {
  TRADE
  KYC
  WALLET
  SYSTEM
  DISPUTE
  ESCROW
}

enum LegalForm {
  SA
  SARL
  SAS
  SNC
  GIE
  SE
  ETS
}

enum Sector {
  AGRICULTURE
  BANKING
  CONSTRUCTION
  ENERGY
  HEALTH
  ICT
  INSURANCE
  MANUFACTURING
  RETAIL
  SERVICES
  TRANSPORT
  OTHER
}

// ═══════════════════════════════════════════════
//  MODELS
// ═══════════════════════════════════════════════

// ── Users & Authentication ──────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role
  kycStatus     KycStatus @default(NOT_SUBMITTED)
  isActive      Boolean  @default(true)
  isSuspended   Boolean  @default(false)
  suspendReason String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  investorProfile  InvestorProfile?
  companyProfile   CompanyProfile?
  wallet           Wallet?
  kycDocuments     KycDocument[]
  notifications    Notification[]
  auditLogsAsActor AuditLog[]       @relation("AuditActor")

  // Trade relations
  buyTrades        Trade[]          @relation("TradeBuyer")
  sellTrades       Trade[]          @relation("TradeSeller")
  disputesRaised   Dispute[]        @relation("DisputeRaiser")
  disputesResolved Dispute[]        @relation("DisputeResolver")

  @@map("users")
}

model InvestorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  firstName     String
  lastName      String
  phone         String?
  dateOfBirth   DateTime?
  nationality   String?  @default("Cameroonian")
  address       String?
  city          String?
  region        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings      ShareHolding[]
  certificates  ShareCertificate[]

  @@map("investor_profiles")
}

model CompanyProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  companyName       String
  legalForm         LegalForm
  rccmNumber        String?   @unique
  niuNumber         String?   @unique
  shareCapital      Decimal?  @db.Decimal(15, 2)
  incorporationDate DateTime?
  sector            Sector?
  address           String?
  city              String?
  region            String?
  poBox             String?
  companyEmail      String?
  companyPhone      String?
  website           String?
  // Legal representative
  repName           String?
  repTitle          String?
  repEmail          String?
  repPhone          String?
  // Verification
  isVerified        Boolean  @default(false)
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings          ShareListing[]
  holdings          ShareHolding[]
  certificates      ShareCertificate[]
  trades            Trade[]

  @@map("company_profiles")
}

// ── KYC & Documents ─────────────────────────────

model KycDocument {
  id          String    @id @default(cuid())
  userId      String
  docType     DocType
  fileName    String
  fileUrl     String
  fileSize    Int?
  status      DocStatus @default(PENDING)
  reviewedBy  String?
  reviewNote  String?
  reviewedAt  DateTime?
  uploadedAt  DateTime  @default(now())

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

// ── Trading ─────────────────────────────────────

model ShareListing {
  id              String        @id @default(cuid())
  companyId       String
  title           String?
  description     String?
  totalShares     Int
  availableShares Int
  pricePerShare   Decimal       @db.Decimal(15, 2)
  minPurchase     Int           @default(1)
  maxPurchase     Int?
  status          ListingStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  company         CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trades          Trade[]

  @@map("share_listings")
}

model Trade {
  id            String      @id @default(cuid())
  tradeRef      String      @unique @default(cuid())
  type          TradeType
  buyerId       String
  sellerId      String?
  companyId     String
  listingId     String?
  shares        Int
  pricePerShare Decimal     @db.Decimal(15, 2)
  totalAmount   Decimal     @db.Decimal(15, 2)
  status        TradeStatus @default(PENDING)
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  buyer         User           @relation("TradeBuyer", fields: [buyerId], references: [id])
  seller        User?          @relation("TradeSeller", fields: [sellerId], references: [id])
  company       CompanyProfile @relation(fields: [companyId], references: [id])
  listing       ShareListing?  @relation(fields: [listingId], references: [id])
  escrow        EscrowHold?
  dispute       Dispute?

  @@map("trades")
}

model EscrowHold {
  id          String       @id @default(cuid())
  tradeId     String       @unique
  amount      Decimal      @db.Decimal(15, 2)
  status      EscrowStatus @default(LOCKED)
  lockedAt    DateTime     @default(now())
  releasedAt  DateTime?

  // Relations
  trade       Trade        @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@map("escrow_holds")
}

// ── Financial ───────────────────────────────────

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  availableBalance Decimal  @default(0) @db.Decimal(15, 2)
  escrowBalance    Decimal  @default(0) @db.Decimal(15, 2)
  totalDeposited   Decimal  @default(0) @db.Decimal(15, 2)
  totalWithdrawn   Decimal  @default(0) @db.Decimal(15, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id            String        @id @default(cuid())
  walletId      String
  type          TxType
  amount        Decimal       @db.Decimal(15, 2)
  balanceAfter  Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod?
  reference     String?
  description   String?
  status        TxStatus      @default(PENDING)
  createdAt     DateTime      @default(now())

  // Relations
  wallet        Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

model ShareHolding {
  id              String   @id @default(cuid())
  investorId      String
  companyId       String
  sharesOwned     Int
  averageCostBasis Decimal @db.Decimal(15, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  investor        InvestorProfile  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  company         CompanyProfile   @relation(fields: [companyId], references: [id])
  certificates    ShareCertificate[]

  @@unique([investorId, companyId])
  @@map("share_holdings")
}

model ShareCertificate {
  id                String   @id @default(cuid())
  holdingId         String
  investorId        String
  companyId         String
  certificateNumber String   @unique
  sharesCount       Int
  issuedAt          DateTime @default(now())
  pdfUrl            String?

  // Relations
  holding           ShareHolding    @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  investor          InvestorProfile @relation(fields: [investorId], references: [id])
  company           CompanyProfile  @relation(fields: [companyId], references: [id])

  @@map("share_certificates")
}

// ── Platform ────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotifType @default(SYSTEM)
  isRead    Boolean   @default(false)
  actionUrl String?
  createdAt DateTime  @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Dispute {
  id           String        @id @default(cuid())
  tradeId      String        @unique
  raisedById   String
  reason       String
  evidence     String?
  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  trade        Trade         @relation(fields: [tradeId], references: [id])
  raisedBy     User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  resolvedBy   User?         @relation("DisputeResolver", fields: [resolvedById], references: [id])

  @@map("disputes")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  target    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  // Relations
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])

  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
